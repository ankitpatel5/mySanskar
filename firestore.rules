rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
          && request.auth.token.email == 'ankitpatel5@gmail.com';
    }

    // ── User profiles ──
    match /users/{userId} {
      allow read:  if request.auth != null
                   && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null
                   && request.auth.uid == userId;
    }

    // ── Per-user playlists ──
    match /users/{userId}/playlists/{playlistId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    // ── Per-user play counts ──
    match /users/{userId}/playCounts/{trackId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    // ── Per-user AI stories ──
    match /users/{userId}/aiStories/{storyId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // ── Per-user story of the day ──
    match /users/{userId}/storyOfDay/{dateStr} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // ── Per-user settings (child profile, etc.) ──
    match /users/{userId}/settings/{docId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // ── Per-user story progress (mark as read) ──
    match /users/{userId}/storyProgress/{storyId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // ── Per-user audiobook progress ──
    match /users/{userId}/audiobookProgress/{bookId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    // ── Global song play counts ──
    match /songs/{trackId} {
      allow read:   if request.auth != null;
      allow write:  if request.auth != null;
    }

    // ── Blocked users list ──
    match /blockedUsers/{uid} {
      // Users can read their own blocked status (checked on login)
      allow read:  if request.auth != null
                   && (request.auth.uid == uid || isAdmin());
      // Only admin can block / unblock
      allow write: if isAdmin();
    }

    // ── VIP TTS access list ──
    // Keyed by email address; users can only read their own status
    match /vipTTSUsers/{email} {
      allow read:  if request.auth != null
                   && (request.auth.token.email == email || isAdmin());
      allow write: if isAdmin();
    }

    // ── Pre-rendered TTS audio index (read by any signed-in user) ──
    match /prerenderedTTS/{storyId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ── Song lyrics (admin writes, any signed-in user reads) ──
    match /songLyrics/{songId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Global audiobook info cache (author, description) ──
    match /audiobookInfo/{bookId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;  // any signed-in user can seed it; admin can delete
      allow delete: if isAdmin();
    }

    // ── User feedback ("Suggest a feature") ──
    // Any signed-in user can submit; only the admin can read/manage.
    match /feedback/{feedbackId} {
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.text is string
                    && request.resource.data.text.size() > 0
                    && request.resource.data.text.size() < 4000;
      allow read, update, delete: if isAdmin();
    }

    // ── Shared playlists (public read, auth write) ──
    match /sharedPlaylists/{shareId} {
      allow read:   if true;
      allow create: if request.auth != null;
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.ownerId;
    }

  }
}
