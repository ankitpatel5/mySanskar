rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
          && request.auth.token.email == 'ankitpatel5@gmail.com';
    }

    // ── User profiles ──
    match /users/{userId} {
      allow read:  if request.auth != null
                   && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null
                   && request.auth.uid == userId;
    }

    // ── Per-user playlists ──
    match /users/{userId}/playlists/{playlistId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    // ── Per-user play counts ──
    match /users/{userId}/playCounts/{trackId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    // ── Per-user AI stories ──
    match /users/{userId}/aiStories/{storyId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // ── Global song play counts ──
    match /songs/{trackId} {
      allow read:   if request.auth != null;
      allow write:  if request.auth != null;
    }

    // ── Blocked users list ──
    match /blockedUsers/{uid} {
      // Users can read their own blocked status (checked on login)
      allow read:  if request.auth != null
                   && (request.auth.uid == uid || isAdmin());
      // Only admin can block / unblock
      allow write: if isAdmin();
    }

    // ── Shared playlists (public read, auth write) ──
    match /sharedPlaylists/{shareId} {
      allow read:   if true;
      allow create: if request.auth != null;
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.ownerId;
    }
  }
}
