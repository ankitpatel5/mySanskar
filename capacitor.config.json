{
  "appId": "com.ankitpatel5.mysanskar",
  "appName": "mySanskar",
  "webDir": "www",
  "ios": {
    "backgroundColor": "#000000",
    "contentInset": "always"
  },
  "android": {
    "backgroundColor": "#000000",
    "adjustMarginsForEdgeToEdge": "force"
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": false,
      "backgroundColor": "#000000",
      "androidSplashResourceName": "splash",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0d0b07",
      "overlaysWebView": false
    }
  }
}
