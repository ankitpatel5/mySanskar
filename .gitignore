# Vercel
.vercel
.env*

# Local config — contains real API keys, never commit
config.js

# Logs & debug
firebase-debug.log
*.log

# Build artifacts
drift-music-player.zip
*.zip

# Capacitor www build dir (generated by scripts/build-www.sh)
www/

# Capacitor iOS derived data / build output (Xcode generates these)
ios/App/App.xcworkspace/xcuserdata/
ios/App/Pods/
ios/App/.build/
ios/DerivedData/

# Firebase config files — contain project API keys, never commit
# Add these manually after cloning (download from Firebase console)
ios/App/App/GoogleService-Info.plist
android/app/google-services.json

# macOS metadata
.DS_Store
**/.DS_Store

# Node dependencies (only needed for generate-translations script)
node_modules/
package-lock.json
package.json

# Translation generation progress checkpoint
.translation-progress.json

# Claude session data
.claude/
