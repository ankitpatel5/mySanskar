# Vercel
.vercel
.env*


# Logs & debug
firebase-debug.log
*.log

# Build artifacts
drift-music-player.zip
*.zip

# Capacitor www build dir (generated by scripts/build-www.sh)
www/

# Capacitor iOS derived data / build output (Xcode generates these)
ios/App/App.xcworkspace/xcuserdata/
ios/App/Pods/
ios/App/.build/
ios/App/build/
ios/DerivedData/

# Capacitor Android build output (Gradle generates these)
android/app/build/
android/app/release/
android/build/
android/.gradle/

# Android signing password — never commit
android/keystore.properties

# Firebase config files — contain project API keys, never commit
# Add these manually after cloning (download from Firebase console)
ios/App/App/GoogleService-Info.plist
android/app/google-services.json

# macOS metadata
.DS_Store
**/.DS_Store

# Node dependencies
node_modules/
package-lock.json
# package.json is committed — Vercel needs it to run npm run build

# Translation generation progress checkpoint
.translation-progress.json

# Claude session data
.claude/

# Local config — contains real API keys, never commit
config.js
